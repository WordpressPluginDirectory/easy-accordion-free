{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "sp-easy-accordion-pro/media-accordion",
  "title": "Media Accordion",
  "category": "sp-easy-accordion-pro-blocks",
  "description": "Present content with images or media for a more engaging and structured layout.",
  "textdomain": "easy-accordion-free",
  "supports": {
    "align": [
      "wide",
      "full"
    ],
    "customClassName": false
  },
  "attributes": {
    "isPreview": {
      "type": "boolean",
      "default": false
    },
    "align": {
      "type": "string",
      "default": "wide"
    }
  },
  "example": {
    "attributes": {
      "isPreview": true
    }
  },
  "editorScript": "sp_eab_admin_index_js",
  "editorStyle": "sp_eab_editor_style",
  "script": [],
  "style": []
}